{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "destination": "main.py"
    },
    {
      "src": "/ws",
      "destination": "main.py"
    },
    {
      "src": "/(.*)",
      "destination": "main.py"
    }
  ]
}
